{
  "name": "skyring",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "pnpm typecheck && pnpm --filter @skyring/client build",
    "dev": "concurrently --kill-others-on-fail --names client,server --prefix-colors cyan,magenta \"pnpm --filter @skyring/client dev\" \"pnpm --filter @skyring/server dev\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "lint": "eslint .",
    "precommit": "pnpm typecheck && pnpm knip --no-exit-code && pnpm exec lint-staged",
    "prepare": "husky",
    "preview": "pnpm --filter @skyring/client preview",
    "start": "pnpm --filter @skyring/server start",
    "test": "vitest run packages",
    "test:coverage": "vitest run packages tests/integration --coverage",
    "test:e2e": "pnpm build && playwright test",
    "test:integration": "vitest run tests/integration",
    "test:soak": "vitest run tests/soak --passWithNoTests",
    "test:watch": "vitest packages",
    "typecheck": "tsc -b --pretty && tsc -p tsconfig.tests.json --noEmit --pretty",
    "verify": "pnpm typecheck && pnpm lint && pnpm knip && pnpm test && pnpm build",
    "verify:full": "pnpm verify && pnpm test:integration && pnpm test:e2e"
  },
  "lint-staged": {
    "*.{cjs,js,mjs,ts}": [
      "eslint",
      "prettier --write --ignore-unknown"
    ],
    "*.{css,html,json,jsonc,md,yaml,yml}": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@playwright/test": "1.61.1",
    "@types/node": "24.10.2",
    "@types/three": "0.185.1",
    "@types/ws": "8.18.1",
    "@typescript/native": "npm:typescript@7.0.2",
    "@vitest/coverage-v8": "4.1.10",
    "concurrently": "10.0.3",
    "eslint": "9.39.5",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-check-file": "3.3.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-sonarjs": "4.2.0",
    "eslint-plugin-unicorn": "65.0.1",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "knip": "6.27.0",
    "lint-staged": "17.1.0",
    "prettier": "3.9.6",
    "tsx": "4.23.1",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "ws": "8.21.1"
  }
}
